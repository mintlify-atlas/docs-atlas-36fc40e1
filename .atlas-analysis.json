  "keyFeatures": [
    "Ephemeral messaging with zero persistence",
    "Optional AES-GCM 256-bit end-to-end encryption",
    "Real-time presence tracking and typing indicators",
    "Message reactions and reply threads",
    "Public and private rooms with customizable settings",
    "Room themes and visual customization",
    "Vote kick and moderation tools",
    "AFK detection and auto-kick",
    "PWA support with offline fallback",
    "Mobile-responsive with swipe gestures"
  ],
  "publicApiSurface": [
    "useChatRoom - Core realtime chat hook",
    "useLobby - Public room discovery hook",
    "useBookmarks - Room bookmark management",
    "useKeyboardShortcuts - Keyboard shortcut handler",
    "useSwipeGesture - Touch swipe detection",
    "ChatInterface - Main chat component",
    "MessageBubble - Message display component",
    "UserSidebar - Online users component",
    "encryptMessage - E2EE encryption utility",
    "decryptMessage - E2EE decryption utility",
    "generateRoomId - Room ID generation",
    "validateUsername - Username validation",
    "getMessageOpacity - Message fade calculation",
    "getUserColor - User color assignment"
  ]
